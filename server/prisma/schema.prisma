generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  
}

// --- ENUMS ---
enum Role {
  USER
  ADMIN
}

enum ProgramStatus {
  PLANNED
  ACTIVE
  INACTIVE
  COMPLETED
  CANCELLED
}

enum DonationStatus {
  PENDING
  COMPLETED
  FAILED
}

enum VolunteerAvailability {
  WEEKDAYS
  WEEKENDS
  EVENINGS
  FLEXIBLE
}

enum VolunteerStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum ProgramCategory {
  SKILL_TRAINING
  LEGAL_AID
  HEALTH_CAMP
  EDUCATION
  RELIEF_DISTRIBUTION
  COMMUNITY_EMPOWERMENT
}

enum EventStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

// --- MODELS ---
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  donations  Donation[]
  volunteers Volunteer[]
}

model Program {
  id                  String          @id @default(uuid())
  name                String
  description         String          @db.Text
  category            ProgramCategory
  startDate           DateTime
  endDate             DateTime?
  status              ProgramStatus   @default(PLANNED)
  targetBeneficiaries Int
  actualBeneficiaries Int?            @default(0)
  location            String
  budget              Decimal         @db.Decimal(10, 2)
  imageUrl            String?         
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  // Relations
  donations Donation[]
  volunteers  Volunteer[]
}

model Donation {
  id             String         @id @default(uuid())
  amount         Decimal        @db.Decimal(10, 2)
  currency       String         @default("INR")
  donorName      String
  donorEmail     String
  isAnonymous    Boolean        @default(false)
  message        String?        @db.Text
  status         DonationStatus @default(PENDING)
  PaymentOrderId String?        @unique
  paymentId      String?
  completedAt    DateTime? 
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt // tracking state changes

  // Relations
  program   Program? @relation(fields: [programId], references: [id])
  programId String?
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
}

model Volunteer {
  id           String                @id @default(uuid())
  name         String
  email        String                @unique
  phone        String?
  skills       String[]              
  interests    String[]              
  availability VolunteerAvailability?
  joinedDate   DateTime              @default(now())
  status       VolunteerStatus       @default(PENDING)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  role         String?               @default("GENERAL")

  // Relations
  user   User?   @relation(fields: [userId], references: [id])
  userId String? @unique // A user can have one volunteer profile
  programId String?
  program   Program? @relation(fields: [programId], references: [id])
}

model Event {
  id          String      @id @default(uuid())
  title       String
  description String      @db.Text
  date        DateTime
  timeString  String      
  location    String
  imageUrl    String?
  status      EventStatus @default(UPCOMING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Post {
  id        String   @id @default(uuid())
  title     String
  excerpt   String
  content   String?  @db.Text
  author    String   @default("Admin Team")
  category  String
  imageUrl  String
  status    String   @default("PUBLISHED")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GalleryImage {
  id        String   @id @default(uuid())
  title     String   
  category  String   
  url       String   
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}