{
  "name": "pws-webapp-root",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "start": "concurrently \"npm run start:server\" \"npm run start:client\"",
    "start:server": "npm run dev --workspace=server",
    "start:client": "npm run dev --workspace=client",
    "build": "npx tsc -p shared/tsconfig.json && npm run build -w @pws/client",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "prepare": "husky"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.5",
    "ts-node": "^10.9.2",
    "turbo": "^2.5.4",
    "typescript": "^5.3.3"
  }
}
